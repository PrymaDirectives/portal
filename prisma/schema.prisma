// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─────────────────────────────────────────────
// Invoice Models
// ─────────────────────────────────────────────

model Invoice {
  id              String   @id @default(cuid())
  publicInvoiceId String   @unique
  invoiceNumber   String   @unique

  // Status & dates
  status     String   @default("unpaid")
  dateIssued DateTime
  paymentDue DateTime
  paidAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Sender
  senderName     String
  senderEmail    String
  senderLocation String
  senderBrand    String

  // Client
  clientName    String
  clientContact String
  clientEmail   String

  // Project
  projectName        String
  projectDescription String

  // Billing
  currency    String @default("USD")
  hoursWorked Float  @default(0)
  hourlyRate  Float  @default(0)
  subtotal    Float
  taxAmount   Float  @default(0)
  totalDue    Float

  // Tools & notes (serialized JSON for SQLite compat)
  toolsUsedJson String @default("[]")
  notes         String @default("")

  // Stripe
  stripeCustomerId        String?
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  stripePaymentLink       String?
  stripeStatus            String?
  webhookLastSyncedAt     DateTime?

  // PDF / Storage
  pdfUrl         String?
  pdfVersion     Int      @default(0)
  pdfGeneratedAt DateTime?

  // Admin / Internal
  internalNotes String?
  createdBy     String?
  lastEditedBy  String?

  // Relations
  lineItems           InvoiceLineItem[]
  stripeWebhookEvents StripeWebhookEvent[]
}

model InvoiceLineItem {
  id        String @id @default(cuid())
  invoiceId String

  item        String
  description String
  hours       Float
  rate        Float
  amount      Float
  sortOrder   Int   @default(0)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model StripeWebhookEvent {
  id            String   @id @default(cuid())
  stripeEventId String   @unique
  type          String
  invoiceId     String?
  payloadJson   String
  processedAt   DateTime @default(now())

  invoice Invoice? @relation(fields: [invoiceId], references: [id])
}

// ─────────────────────────────────────────────
// Invoice Templates
// ─────────────────────────────────────────────

model InvoiceTemplate {
  id          String @id @default(cuid())
  name        String
  ownerEmail  String // e.g. peter.dodge@pryma.tech
  description String @default("")

  // Sender defaults
  senderName     String @default("")
  senderEmail    String @default("")
  senderLocation String @default("")
  senderBrand    String @default("")

  // Client defaults
  clientName    String @default("")
  clientContact String @default("")
  clientEmail   String @default("")

  // Project defaults
  projectName        String @default("")
  projectDescription String @default("")

  // Billing defaults
  currency    String @default("USD")
  hourlyRate  Float  @default(0)
  taxAmount   Float  @default(0)

  // Tools & notes defaults
  toolsUsedJson String @default("[]")
  notes         String @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems TemplateLineItem[]
}

model TemplateLineItem {
  id         String @id @default(cuid())
  templateId String

  item        String
  description String @default("")
  hours       Float  @default(0)
  rate        Float  @default(0)
  amount      Float  @default(0)
  sortOrder   Int    @default(0)

  template InvoiceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────────
// Stripe Subscriptions
// ─────────────────────────────────────────────

model Subscription {
  id String @id @default(cuid())

  // Client
  clientName  String
  clientEmail String

  // Plan
  planName    String
  description String @default("")
  amount      Float  // in dollars
  interval    String @default("month") // month | year

  // Status
  status String @default("active") // active | canceled | past_due | trialing | incomplete

  // Stripe
  stripeCustomerId     String?
  stripeSubscriptionId String? @unique
  stripePriceId        String?
  stripeProductId      String?

  // Dates
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  canceledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}
